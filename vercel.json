{
  "version": 2,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/landing-page/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/landing-page",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/quote-follow-up-software",
      "destination": "/quote-follow-up-software/",
      "permanent": true
    },
    {
      "source": "/landing-page/quote-follow-up-software.html",
      "destination": "/quote-follow-up-software/",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.quotechaser.online"
        }
      ],
      "destination": "https://quotechaser.online/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
